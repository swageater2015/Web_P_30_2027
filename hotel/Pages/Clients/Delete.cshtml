@page
@model Hotel.Pages.Clients.DeleteModel

<div class="container mt-4">
    <div class="card border-danger shadow-lg">
        <div class="card-header bg-danger text-white">
            <h2 class="mb-0">⚠️ Удаление клиента</h2>
        </div>
        <div class="card-body">
            <div class="alert alert-warning">
                <h4>Вы уверены, что хотите удалить клиента <strong>@Model.Client.LastName</strong>?</h4>
            </div>
            <div class="card bg-light">
                <div class="card-body">
                    <p><strong> Телефон:</strong> @Model.Client.Phone</p>
                    <p><strong> Email:</strong> @Model.Client.Email</p>
                </div>
            </div>
        </div>
        <div class="card-footer">
            <form method="post">
                <input type="hidden" asp-for="Client.Id" />
                <button type="submit" class="btn btn-danger"> Да, удалить</button>
                <a asp-page="Index" class="btn btn-secondary">Отмена</a>
            </form>
        </div>
    </div>
</div>