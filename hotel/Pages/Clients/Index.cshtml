@page
@model Hotel.Pages.Clients.IndexModel
@{
}
<h1>Список клиентов</h1>

<p>
    <a asp-page="Create">Добавить клиента</a>
</p>

<table border="1" cellpadding="5">
    <thead>
        <tr>
            <th>Фамилия и имя</th>
            <th>Телефон</th>
            <th>Email</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var client in Model.Clients)
        {
            <tr>
                <td>@client.LastName</td>
                <td>@client.Phone</td>
                <td>@client.Email</td>
                <td>
                    <a asp-page="Details" asp-route-id="@client.Id">Открыть</a>
                    <a asp-page="Edit" asp-route-id="@client.Id">Изменить</a>
                    <a asp-page="Delete" asp-route-id="@client.Id">Удалить</a>
                </td>
            </tr>
        }
    </tbody>
</table>