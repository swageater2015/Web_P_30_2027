@page
@model Hotel.Pages.Clients.DetailsModel

<h1 class="mb-4">Информация о клиенте</h1>

<div class="card col-md-6">
    <div class="card-body">
        <p><strong>Фамилия и имя:</strong> @Model.Client?.LastName</p>
        <p><strong>Телефон:</strong> @Model.Client?.Phone</p>
        <p><strong>Email:</strong> @Model.Client?.Email</p>
    </div>
</div>

<p class="mt-3">
    <a asp-page="Index" class="btn btn-secondary">Назад к списку</a>
</p>