@page
@model Hotel.Pages.Clients.DetailsModel

<div class="container mt-4">
    <div class="card shadow-lg">
        <div class="card-header bg-success text-white">
            <h2 class="mb-0">@Model.Client.LastName</h2>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-6">
                    <p><strong> Телефон:</strong> @Model.Client.Phone</p>
                    <p><strong> Email:</strong> @Model.Client.Email</p>
                </div>
                <div class="col-md-6 text-center">
                    <i class="bi bi-person-circle" style="font-size: 5rem;"></i>
                </div>
            </div>
        </div>
        <div class="card-footer">
            <a asp-page="Index" class="btn btn-secondary">← Назад</a>
            <a asp-page="Edit" asp-route-id="@Model.Client.Id" class="btn btn-warning"> Редактировать</a>
            <a asp-page="Delete" asp-route-id="@Model.Client.Id" class="btn btn-danger"> Удалить</a>
        </div>
    </div>
</div>